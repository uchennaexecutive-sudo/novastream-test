{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main",
    "browser-fetch-bridge"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "allow-search-hianime",
    "allow-get-hianime-episodes",
    "allow-get-hianime-stream",
    "allow-fetch-anime-text",
    "allow-get-anime-debug-log-path",
    "allow-browser-fetch-bridge-ready",
    "allow-complete-browser-fetch",
    "allow-complete-resolver-eval",
    "allow-resolver-session-eval",
    "allow-fetch-anime-text-with-session",
    "allow-fetch-hls-segment",
    "allow-fetch-hls-manifest",
    "allow-fetch-movie-segment",
    "allow-fetch-movie-manifest",
    "allow-fetch-movie-subtitles",
    "allow-fetch-movie-text",
    "allow-fetch-movie-resolver-streams",
    "allow-probe-movie-stream",
    "allow-register-media-proxy-stream",
    "allow-register-media-proxy-file",
    "allow-get-cast-relay-status",
    "allow-prepare-cast-media",
    "allow-clear-cast-relay",
    "allow-discover-cast-devices",
    "allow-get-cast-session-status",
    "allow-connect-cast-device",
    "allow-disconnect-cast-device",
    "allow-find-local-subtitle-sidecar",
    "allow-read-local-text-file",
    "allow-open-iframe-player-window",
    "allow-resolve-embed-stream",
    "allow-fetch-ann-feed",
    "allow-fetch-og-image",
    "allow-start-video-download",
    "allow-pause-video-download",
    "allow-cancel-video-download",
    "allow-delete-video-download",
    "allow-get-downloads-storage-info",
    "allow-get-download-location",
    "allow-set-download-location",
    "allow-reset-download-location",
    "allow-set-video-download-max-concurrent",
    "allow-scan-download-library",
    "allow-get-local-file-metadata",
    "allow-get-runtime-environment",
    "allow-fetch-anime-json",
    "allow-capture-stream",
    "allow-set-topmost-state",
    "allow-download-update",
    "allow-apply-update",
    "allow-get-watch-party-transport-config",
    "allow-create-watch-party-token",
    "process:default",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-is-maximized",
    "core:window:allow-start-dragging",
    "allow-set-player-fullscreen"
  ]
}
