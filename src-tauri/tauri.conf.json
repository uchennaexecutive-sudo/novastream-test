{
  "productName": "NOVA STREAM",
  "version": "1.4.3",
  "identifier": "com.novastream.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "NOVA STREAM",
        "width": 1440,
        "height": 900,
        "minWidth": 1280,
        "minHeight": 720,
        "resizable": true,
        "maximized": true,
        "devtools": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": true,
      "freezePrototype": false
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app"
    ],
    "icon": [
      "icons/icon.png"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMyMTNGMDhDNzc2MjkyNTEKUldSUmttSjNqUEFUd3F5QXc4THBXa1MyamRXaFkrNzU2SXNsMS9zcTZYdnVYWW9DYldZcjRGbG0K",
      "endpoints": [
        "https://raw.githubusercontent.com/uchennaexecutive-sudo/novastream/main/updates/latest.json"
      ]
    }
  }
}
